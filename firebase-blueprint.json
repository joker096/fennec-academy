{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user progress, settings, and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "bio": { "type": "string", "description": "A short biography of the user." },
        "location": { "type": "string", "description": "The user's location." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role (user or admin)." },
        "xp": { "type": "integer", "description": "Total experience points." },
        "caps": { "type": "integer", "description": "Total currency (caps)." },
        "stimpaks": { "type": "integer", "description": "Total health items." },
        "hp": { "type": "integer", "description": "Current health points." },
        "daysSurvived": { "type": "integer", "description": "Number of days survived (streak)." },
        "targetLang": { "type": "string", "description": "The language the user is learning." },
        "uiLang": { "type": "string", "description": "The user's preferred UI language." },
        "visualEffects": { "type": "boolean", "description": "Whether visual effects (dark mode) are enabled." },
        "equippedPerks": { "type": "array", "items": { "type": "string" }, "description": "List of equipped perk IDs." },
        "completedLessons": { "type": "array", "items": { "type": "string" }, "description": "List of completed lesson IDs." },
        "completedMiniLessons": { "type": "array", "items": { "type": "string" }, "description": "List of completed mini lesson IDs." },
        "flashcardProgress": { "type": "object", "description": "Map of flashcard IDs to progress data." },
        "mistakes": { "type": "object", "description": "Map of word IDs to mistake data." },
        "tasks": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "dueDate": { "type": "string", "format": "date-time" },
              "completed": { "type": "boolean" },
              "xpReward": { "type": "integer" },
              "priority": { "type": "string", "enum": ["low", "medium", "high"] },
              "reminderType": { "type": "string", "enum": ["none", "at_due_date", "1_day_before", "1_hour_before"] },
              "reminderSent": { "type": "boolean" }
            },
            "required": ["id", "title", "dueDate", "completed"]
          }, 
          "description": "List of active tasks/objectives." 
        },
        "dailyProgress": { "type": "object", "description": "Daily progress tracking data." },
        "special": { "type": "object", "description": "S.P.E.C.I.A.L. stats map." },
        "specialProgress": { "type": "object", "description": "Progress towards the next level for each S.P.E.C.I.A.L. stat." },
        "weather": { "type": "string", "enum": ["clear", "rain", "dust_storm", "acid_rain", "fog"], "description": "Current weather in the wasteland." },
        "isPremium": { "type": "boolean", "description": "Whether the user has premium status." },
        "hunger": { "type": "integer", "description": "Current hunger level." },
        "thirst": { "type": "integer", "description": "Current thirst level." },
        "avatarId": { "type": "string", "description": "The ID of the user's selected avatar." },
        "accessories": { "type": "object", "description": "Map of selected accessories (hat, glasses)." },
        "gender": { "type": "string", "enum": ["male", "female"], "description": "The user's gender." },
        "achievements": { "type": "object", "description": "Map of unlocked achievements." },
        "perfectLessonsCount": { "type": "integer", "description": "Count of lessons completed with 100% accuracy." },
        "unlockedRooms": { "type": "array", "items": { "type": "string" }, "description": "List of unlocked room IDs." },
        "savedExamples": { "type": "array", "items": { "type": "object" }, "description": "List of saved word examples." },
        "lastPlayedDate": { "type": "string", "description": "The last date the user played (YYYY-MM-DD)." },
        "nativeLang": { "type": "string", "description": "The user's native language." },
        "factionId": { "type": "string", "description": "The ID of the faction the user has joined." },
        "factionXp": { "type": "integer", "description": "Experience points earned within the faction leagues." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "The last time the profile was updated." }
      },
      "required": ["uid", "email"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Stores global application settings like ad codes and analytics.",
      "type": "object",
      "properties": {
        "googleAnalyticsId": { "type": "string", "description": "Google Analytics Measurement ID." },
        "yandexMetricaId": { "type": "string", "description": "Yandex Metrica ID." },
        "adCodeHeader": { "type": "string", "description": "Ad code to be placed in the header." },
        "adCodeFooter": { "type": "string", "description": "Ad code to be placed in the footer." },
        "adCodeSidebar": { "type": "string", "description": "Ad code to be placed in the sidebar." },
        "customScripts": { "type": "string", "description": "Any additional custom scripts." }
      }
    },
    "CachedExample": {
      "title": "Cached Example",
      "description": "Stores AI-generated contextual examples for words to be shared across all users.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "targetLang": { "type": "string" },
        "uiLang": { "type": "string" },
        "examples": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sentence": { "type": "string" },
              "translation": { "type": "string" },
              "source": { "type": "string", "enum": ["news", "books", "social media"] },
              "sourceName": { "type": "string" }
            },
            "required": ["sentence", "translation", "source", "sourceName"]
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "targetLang", "uiLang", "examples", "lastUpdated"]
    },
    "CachedKnowledge": {
      "title": "Cached Knowledge",
      "description": "Stores various AI-generated learning insights (grammar, vocabulary, etc.) for shared access.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["grammar", "vocabulary", "deep_dive", "correct_explanation"] },
        "key": { "type": "string", "description": "Unique key for the item (e.g., word or hash of question)." },
        "targetLang": { "type": "string" },
        "uiLang": { "type": "string" },
        "data": { "type": "object", "description": "The actual JSON data returned by AI." },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "key", "targetLang", "uiLang", "data", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles, keyed by UID."
    },
    "/settings/global": {
      "schema": "GlobalSettings",
      "description": "Global settings document."
    },
    "/cached_examples/{cacheId}": {
      "schema": "CachedExample",
      "description": "Collection of cached contextual examples, keyed by a composite ID (word_targetLang_uiLang)."
    },
    "/cached_knowledge/{cacheId}": {
      "schema": "CachedKnowledge",
      "description": "Shared cache for grammar, vocabulary, and linguistic insights."
    }
  }
}
