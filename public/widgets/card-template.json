{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "Container",
      "backgroundImage": {
        "url": "https://ais-dev-2lflgxbbmu2kwt55v6miru-25414342641.europe-west1.run.app/perks/intelligence.webp",
        "fillMode": "cover",
        "horizontalAlignment": "center",
        "verticalAlignment": "center"
      },
      "items": [
        {
          "type": "TextBlock",
          "size": "ExtraLarge",
          "weight": "Bolder",
          "text": "${word}",
          "horizontalAlignment": "Center",
          "color": "Light"
        },
        {
          "type": "TextBlock",
          "text": "${translation}",
          "size": "Medium",
          "weight": "Lighter",
          "wrap": true,
          "horizontalAlignment": "Center",
          "color": "Light"
        },
        {
          "type": "TextBlock",
          "text": "${transcription}",
          "size": "Small",
          "isSubtle": true,
          "horizontalAlignment": "Center",
          "color": "Light"
        }
      ],
      "bleed": true,
      "minHeight": "100px"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Practice",
      "url": "https://ais-dev-2lflgxbbmu2kwt55v6miru-25414342641.europe-west1.run.app/flashcards"
    },
    {
      "type": "Action.Execute",
      "title": "Refresh",
      "verb": "refresh",
      "id": "refresh-btn"
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}
