rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User documents — any authenticated user can read/write
    // (Supabase UID may differ from Firebase Auth UID)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Settings — readable by anyone, writable by authenticated users
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Leaderboard — publicly readable, writable by authenticated users
    match /leaderboard/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Catch-all for any other collection
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
